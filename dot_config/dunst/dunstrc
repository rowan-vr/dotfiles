[global]
    monitor = 0
    follow = mouse
    width = 320
    height = 300
    origin = top-right
    offset = 16x48
    corner_radius = 8
    frame_width = 2
    separator_height = 2
    font = JetBrainsMono Nerd Font 10
    markup = full
    format = <b>%s</b>\n%b
    idle_threshold = 120
    background = "#1e1e2e"
    foreground = "#cdd6f4"
    frame_color = "#89b4fa"
    timeout = 6